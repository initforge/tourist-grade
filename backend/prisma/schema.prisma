generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  COORDINATOR
  SALES
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TourTransport {
  XE
  MAYBAY
}

enum TourType {
  MUA_LE
  QUANH_NAM
}

enum TourProgramStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum TourInstanceStatus {
  CHO_DUYET_BAN
  YEU_CAU_CHINH_SUA
  DANG_MO_BAN
  CHUA_DU_KIEN
  DA_HUY
  CHO_NHAN_DIEU_HANH
  CHO_DU_TOAN
  CHO_DUYET_DU_TOAN
  SAN_SANG_TRIEN_KHAI
  DANG_TRIEN_KHAI
  CHO_QUYET_TOAN
  HOAN_THANH
}

enum BookingStatus {
  BOOKED
  PENDING
  PENDING_CANCEL
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum RefundStatus {
  NONE
  PENDING
  REFUNDED
  NOT_REQUIRED
}

enum PaymentMethod {
  VNPAY
  STRIPE
}

enum PaymentType {
  ONLINE
  OFFLINE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum PassengerType {
  ADULT
  CHILD
  INFANT
}

enum Gender {
  MALE
  FEMALE
}

enum VoucherType {
  PERCENT
  FIXED
}

enum VoucherStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  ACTIVE
  INACTIVE
}

enum SupplierType {
  TRANSPORT
  HOTEL
  RESTAURANT
  ATTRACTION
  GUIDE
  OTHER
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  passwordHash       String?
  fullName           String
  phone              String?
  role               Role
  status             UserStatus     @default(ACTIVE)
  avatarUrl          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  customerBookings   Booking[]      @relation("CustomerBookings")
  createdPrograms    TourProgram[]  @relation("ProgramCreatedBy")
  updatedPrograms    TourProgram[]  @relation("ProgramUpdatedBy")
  createdInstances   TourInstance[] @relation("InstanceCreatedBy")
  approvedInstances  TourInstance[] @relation("InstanceApprovedBy")
  assignedInstances  TourInstance[] @relation("InstanceAssignedCoordinator")
  confirmedBookings  Booking[]      @relation("BookingConfirmedBy")
  refundedBookings   Booking[]      @relation("BookingRefundedBy")
  createdVouchers    Voucher[]      @relation("VoucherCreatedBy")
  approvedVouchers   Voucher[]      @relation("VoucherApprovedBy")
  rejectedVouchers   Voucher[]      @relation("VoucherRejectedBy")
  refreshTokens      RefreshToken[]
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TourProgram {
  id                String            @id @default(cuid())
  code              String            @unique
  name              String
  slug              String            @unique
  description       String?
  departurePoint    String
  arrivalPoint      String?
  sightseeingSpots  Json
  durationDays      Int
  durationNights    Int
  transport         TourTransport
  tourType          TourType
  holidayLabel      String?
  bookingDeadline   Int
  status            TourProgramStatus @default(DRAFT)
  itineraryJson     Json
  pricingConfigJson Json
  createdById       String
  updatedById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  createdBy         User              @relation("ProgramCreatedBy", fields: [createdById], references: [id])
  updatedBy         User?             @relation("ProgramUpdatedBy", fields: [updatedById], references: [id])
  instances         TourInstance[]
  voucherTargets    VoucherTarget[]

  @@index([status])
}

model TourInstance {
  id                    String             @id @default(cuid())
  code                  String             @unique
  programId             String
  programNameSnapshot   String
  departureDate         DateTime
  bookingDeadlineAt     DateTime
  status                TourInstanceStatus
  departurePoint        String
  arrivalPoint          String?
  sightseeingSpots      Json
  transport             TourTransport
  expectedGuests        Int
  minParticipants       Int
  priceAdult            Decimal            @db.Decimal(12, 2)
  priceChild            Decimal            @db.Decimal(12, 2)
  priceInfant           Decimal?           @db.Decimal(12, 2)
  warningDate           DateTime?
  costEstimateJson      Json?
  settlementJson        Json?
  assignedCoordinatorId String?
  createdById           String
  approvedById          String?
  submittedAt           DateTime?
  approvedAt            DateTime?
  openedAt              DateTime?
  closedAt              DateTime?
  receivedAt            DateTime?
  estimatedAt           DateTime?
  estimateApprovedAt    DateTime?
  readyAt               DateTime?
  startedAt             DateTime?
  endedAt               DateTime?
  settledAt             DateTime?
  cancelledAt           DateTime?
  cancelReason          String?
  refundTotal           Decimal?           @db.Decimal(12, 2)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  program               TourProgram        @relation(fields: [programId], references: [id], onDelete: Restrict)
  assignedCoordinator   User?              @relation("InstanceAssignedCoordinator", fields: [assignedCoordinatorId], references: [id])
  createdBy             User               @relation("InstanceCreatedBy", fields: [createdById], references: [id])
  approvedBy            User?              @relation("InstanceApprovedBy", fields: [approvedById], references: [id])
  bookings              Booking[]

  @@index([programId, status])
  @@index([departureDate])
}

model Booking {
  id                     String         @id @default(cuid())
  bookingCode            String         @unique
  tourInstanceId         String
  userId                 String?
  status                 BookingStatus
  refundStatus           RefundStatus
  paymentMethod          PaymentMethod
  paymentType            PaymentType
  paymentStatus          PaymentStatus
  contactName            String
  contactEmail           String
  contactPhone           String
  contactNote            String?
  bankInfoJson           Json?
  roomCountsJson         Json?
  totalAmount            Decimal        @db.Decimal(12, 2)
  paidAmount             Decimal        @db.Decimal(12, 2)
  remainingAmount        Decimal        @db.Decimal(12, 2)
  discountAmount         Decimal?       @db.Decimal(12, 2)
  refundAmount           Decimal?       @db.Decimal(12, 2)
  refundBillUrl          String?
  cancellationReason     String?
  cancelledAt            DateTime?
  confirmedById          String?
  confirmedAt            DateTime?
  refundedById           String?
  refundedAt             DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  tourInstance           TourInstance   @relation(fields: [tourInstanceId], references: [id], onDelete: Restrict)
  customer               User?          @relation("CustomerBookings", fields: [userId], references: [id])
  confirmedBy            User?          @relation("BookingConfirmedBy", fields: [confirmedById], references: [id])
  refundedBy             User?          @relation("BookingRefundedBy", fields: [refundedById], references: [id])
  passengers             BookingPassenger[]
  paymentTransactions    PaymentTransaction[]

  @@index([tourInstanceId, status])
  @@index([userId])
}

model BookingPassenger {
  id                   String        @id @default(cuid())
  bookingId            String
  type                 PassengerType
  fullName             String
  dateOfBirth          DateTime?
  gender               Gender
  cccd                 String?
  nationality          String?
  singleRoomSupplement Decimal?      @db.Decimal(12, 2)
  createdAt            DateTime      @default(now())

  booking              Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model PaymentTransaction {
  id              String        @id @default(cuid())
  bookingId       String
  amount          Decimal       @db.Decimal(12, 2)
  method          PaymentMethod
  status          PaymentStatus
  paidAt          DateTime?
  transactionRef  String?
  payloadJson     Json?
  createdAt       DateTime      @default(now())

  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model Voucher {
  id              String         @id @default(cuid())
  code            String         @unique
  type            VoucherType
  valueAmount     Decimal        @db.Decimal(12, 2)
  startsAt        DateTime
  endsAt          DateTime
  usageLimit      Int
  usedCount       Int            @default(0)
  status          VoucherStatus
  description     String?
  rejectionReason String?
  createdById     String?
  approvedById    String?
  rejectedById    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdBy       User?          @relation("VoucherCreatedBy", fields: [createdById], references: [id])
  approvedBy      User?          @relation("VoucherApprovedBy", fields: [approvedById], references: [id])
  rejectedBy      User?          @relation("VoucherRejectedBy", fields: [rejectedById], references: [id])
  targets         VoucherTarget[]

  @@index([status])
}

model VoucherTarget {
  voucherId      String
  tourProgramId  String

  voucher        Voucher     @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  tourProgram    TourProgram @relation(fields: [tourProgramId], references: [id], onDelete: Cascade)

  @@id([voucherId, tourProgramId])
}

model Supplier {
  id                String                  @id @default(cuid())
  name              String
  phone             String
  address           String?
  type              SupplierType
  rating            Decimal?                @db.Decimal(3, 2)
  coverageJson      Json?
  standardsJson     Json?
  isActive          Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  serviceVariants   SupplierServiceVariant[]
}

model SupplierServiceVariant {
  id               String    @id @default(cuid())
  supplierId       String
  name             String
  unit             String
  description      String?
  basePrice        Decimal   @db.Decimal(12, 2)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  supplier         Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model BlogPost {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  category         String
  excerpt          String?
  contentMarkdown  String
  coverImageUrl    String?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
