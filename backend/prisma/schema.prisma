generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  COORDINATOR
  SALES
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TourTransport {
  XE
  MAYBAY
}

enum TourType {
  MUA_LE
  QUANH_NAM
}

enum TourProgramStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum TourInstanceStatus {
  CHO_DUYET_BAN
  YEU_CAU_CHINH_SUA
  TU_CHOI_BAN
  DANG_MO_BAN
  CHUA_DU_KIEN
  DA_HUY
  CHO_NHAN_DIEU_HANH
  CHO_DU_TOAN
  CHO_DUYET_DU_TOAN
  SAN_SANG_TRIEN_KHAI
  DANG_TRIEN_KHAI
  CHO_QUYET_TOAN
  HOAN_THANH
}

enum BookingStatus {
  PENDING
  PENDING_CANCEL
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum RefundStatus {
  NONE
  PENDING
  REFUNDED
  NOT_REQUIRED
}

enum PaymentMethod {
  VNPAY
  STRIPE
  PAYOS
}

enum PaymentType {
  ONLINE
  OFFLINE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  CANCELLED
}

enum PassengerType {
  ADULT
  CHILD
  INFANT
}

enum Gender {
  MALE
  FEMALE
}

enum VoucherType {
  PERCENT
  FIXED
}

enum VoucherStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  ACTIVE
  INACTIVE
}

enum SupplierType {
  TRANSPORT
  HOTEL
  RESTAURANT
  ATTRACTION
  GUIDE
  OTHER
}

enum ServiceCategory {
  ATTRACTION_TICKET
  OTHER
}

enum ServicePriceMode {
  QUOTED
  LISTED
}

enum ServicePriceSetup {
  COMMON
  BY_AGE
  NONE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum FormulaOption {
  BY_DAY
  DEFAULT_VALUE
  MANUAL
}

enum EmailOutboxStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  passwordHash       String?
  fullName           String
  phone              String?
  role               Role
  status             UserStatus     @default(ACTIVE)
  avatarUrl          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  customerBookings   Booking[]      @relation("CustomerBookings")
  createdPrograms    TourProgram[]  @relation("ProgramCreatedBy")
  updatedPrograms    TourProgram[]  @relation("ProgramUpdatedBy")
  createdInstances   TourInstance[] @relation("InstanceCreatedBy")
  approvedInstances  TourInstance[] @relation("InstanceApprovedBy")
  assignedInstances  TourInstance[] @relation("InstanceAssignedCoordinator")
  confirmedBookings  Booking[]      @relation("BookingConfirmedBy")
  cancelledConfirmedBookings Booking[] @relation("BookingCancelledConfirmedBy")
  refundedBookings   Booking[]      @relation("BookingRefundedBy")
  refundBillEditedBookings Booking[] @relation("BookingRefundBillEditedBy")
  createdVouchers    Voucher[]      @relation("VoucherCreatedBy")
  approvedVouchers   Voucher[]      @relation("VoucherApprovedBy")
  rejectedVouchers   Voucher[]      @relation("VoucherRejectedBy")
  wishlistItems      WishlistItem[]
  tourReviews        TourReview[]
  refreshTokens      RefreshToken[]
  emailOutboxEntries EmailOutbox[]  @relation("EmailOutboxCreatedBy")
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TourProgram {
  id                String            @id @default(cuid())
  code              String            @unique
  name              String
  slug              String            @unique
  description       String?
  departurePoint    String
  arrivalPoint      String?
  sightseeingSpots  Json
  durationDays      Int
  durationNights    Int
  transport         TourTransport
  tourType          TourType
  holidayLabel      String?
  bookingDeadline   Int
  status            TourProgramStatus @default(DRAFT)
  itineraryJson     Json
  pricingConfigJson Json
  publicContentJson Json?
  createdById       String
  updatedById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  createdBy         User              @relation("ProgramCreatedBy", fields: [createdById], references: [id])
  updatedBy         User?             @relation("ProgramUpdatedBy", fields: [updatedById], references: [id])
  instances         TourInstance[]
  voucherTargets    VoucherTarget[]
  wishlistItems     WishlistItem[]
  reviews           TourReview[]

  @@index([status])
}

model TourInstance {
  id                    String             @id @default(cuid())
  code                  String             @unique
  programId             String
  programNameSnapshot   String
  departureDate         DateTime
  bookingDeadlineAt     DateTime
  status                TourInstanceStatus
  departurePoint        String
  arrivalPoint          String?
  sightseeingSpots      Json
  transport             TourTransport
  expectedGuests        Int
  minParticipants       Int
  priceAdult            Decimal            @db.Decimal(12, 2)
  priceChild            Decimal            @db.Decimal(12, 2)
  priceInfant           Decimal?           @db.Decimal(12, 2)
  warningDate           DateTime?
  costEstimateJson      Json?
  settlementJson        Json?
  assignedCoordinatorId String?
  createdById           String
  approvedById          String?
  submittedAt           DateTime?
  approvedAt            DateTime?
  openedAt              DateTime?
  closedAt              DateTime?
  receivedAt            DateTime?
  estimatedAt           DateTime?
  estimateApprovedAt    DateTime?
  readyAt               DateTime?
  startedAt             DateTime?
  endedAt               DateTime?
  settledAt             DateTime?
  cancelledAt           DateTime?
  cancelReason          String?
  refundTotal           Decimal?           @db.Decimal(12, 2)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  program               TourProgram        @relation(fields: [programId], references: [id], onDelete: Restrict)
  assignedCoordinator   User?              @relation("InstanceAssignedCoordinator", fields: [assignedCoordinatorId], references: [id])
  createdBy             User               @relation("InstanceCreatedBy", fields: [createdById], references: [id])
  approvedBy            User?              @relation("InstanceApprovedBy", fields: [approvedById], references: [id])
  bookings              Booking[]
  reviews               TourReview[]

  @@index([programId, status])
  @@index([departureDate])
}

model Booking {
  id                     String         @id @default(cuid())
  bookingCode            String         @unique
  tourInstanceId         String
  userId                 String?
  status                 BookingStatus
  refundStatus           RefundStatus
  paymentMethod          PaymentMethod
  paymentType            PaymentType
  paymentStatus          PaymentStatus
  contactName            String
  contactEmail           String
  contactPhone           String
  contactNote            String?
  payloadJson            Json?
  bankInfoJson           Json?
  roomCountsJson         Json?
  totalAmount            Decimal        @db.Decimal(12, 2)
  paidAmount             Decimal        @db.Decimal(12, 2)
  remainingAmount        Decimal        @db.Decimal(12, 2)
  discountAmount         Decimal?       @db.Decimal(12, 2)
  refundAmount           Decimal?       @db.Decimal(12, 2)
  refundBillUrl          String?
  cancellationReason     String?
  cancelledAt            DateTime?
  confirmedById          String?
  confirmedAt            DateTime?
  cancelledConfirmedById String?
  cancelledConfirmedAt   DateTime?
  refundedById           String?
  refundedAt             DateTime?
  refundBillEditedById   String?
  refundBillEditedAt     DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  tourInstance           TourInstance   @relation(fields: [tourInstanceId], references: [id], onDelete: Restrict)
  customer               User?          @relation("CustomerBookings", fields: [userId], references: [id])
  confirmedBy            User?          @relation("BookingConfirmedBy", fields: [confirmedById], references: [id])
  cancelledConfirmedBy   User?          @relation("BookingCancelledConfirmedBy", fields: [cancelledConfirmedById], references: [id])
  refundedBy             User?          @relation("BookingRefundedBy", fields: [refundedById], references: [id])
  refundBillEditedBy     User?          @relation("BookingRefundBillEditedBy", fields: [refundBillEditedById], references: [id])
  passengers             BookingPassenger[]
  paymentTransactions    PaymentTransaction[]
  review                 TourReview?

  @@index([tourInstanceId, status])
  @@index([userId])
}

model BookingPassenger {
  id                   String        @id @default(cuid())
  bookingId            String
  type                 PassengerType
  fullName             String
  dateOfBirth          DateTime?
  gender               Gender
  cccd                 String?
  nationality          String?
  singleRoomSupplement Decimal?      @db.Decimal(12, 2)
  createdAt            DateTime      @default(now())

  booking              Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model PaymentTransaction {
  id              String        @id @default(cuid())
  bookingId       String
  amount          Decimal       @db.Decimal(12, 2)
  method          PaymentMethod
  status          PaymentStatus
  paidAt          DateTime?
  orderCode       String?
  transactionRef  String?
  payloadJson     Json?
  createdAt       DateTime      @default(now())

  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model EmailOutbox {
  id            String           @id @default(cuid())
  template      String
  recipient     String
  subject       String
  payloadJson   Json
  status        EmailOutboxStatus @default(PENDING)
  bookingId     String?
  voucherId     String?
  createdById   String?
  sentAt        DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  createdBy     User?            @relation("EmailOutboxCreatedBy", fields: [createdById], references: [id])

  @@index([template, createdAt])
  @@index([bookingId])
  @@index([voucherId])
}

model SpecialDay {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  occasion    String
  startDate   DateTime
  endDate     DateTime
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startDate, endDate])
}

model Province {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String   @unique
  hasAirport Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Voucher {
  id              String         @id @default(cuid())
  code            String         @unique
  type            VoucherType
  valueAmount     Decimal        @db.Decimal(12, 2)
  startsAt        DateTime
  endsAt          DateTime
  usageLimit      Int
  usedCount       Int            @default(0)
  status          VoucherStatus
  description     String?
  rejectionReason String?
  createdById     String?
  approvedById    String?
  rejectedById    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdBy       User?          @relation("VoucherCreatedBy", fields: [createdById], references: [id])
  approvedBy      User?          @relation("VoucherApprovedBy", fields: [approvedById], references: [id])
  rejectedBy      User?          @relation("VoucherRejectedBy", fields: [rejectedById], references: [id])
  targets         VoucherTarget[]

  @@index([status])
}

model VoucherTarget {
  voucherId      String
  tourProgramId  String

  voucher        Voucher     @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  tourProgram    TourProgram @relation(fields: [tourProgramId], references: [id], onDelete: Cascade)

  @@id([voucherId, tourProgramId])
}

model Supplier {
  id                String                  @id @default(cuid())
  name              String
  phone             String
  email             String?
  address           String?
  type              SupplierType
  serviceSummary    String?
  operatingArea     String?
  establishedYear   Int?
  description       String?
  rating            Decimal?                @db.Decimal(3, 2)
  coverageJson      Json?
  standardsJson     Json?
  isActive          Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  serviceVariants   SupplierServiceVariant[]
}

model SupplierServiceVariant {
  id               String    @id @default(cuid())
  supplierId       String
  name             String
  unit             String
  description      String?
  basePrice        Decimal   @db.Decimal(12, 2)
  quantity         Int?
  capacity         Int?
  transportType    TourTransport?
  priceMode        ServicePriceMode?
  menu             String?
  note             String?
  isMealService    Boolean   @default(false)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  supplier         Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  prices           SupplierServicePrice[]

  @@index([supplierId])
}

model SupplierServicePrice {
  id               String                 @id @default(cuid())
  serviceVariantId String
  unitPrice        Decimal                @db.Decimal(12, 2)
  fromDate         DateTime
  toDate           DateTime
  note             String?
  createdByName    String
  createdAt        DateTime               @default(now())

  serviceVariant   SupplierServiceVariant @relation(fields: [serviceVariantId], references: [id], onDelete: Cascade)

  @@index([serviceVariantId])
}

model Service {
  id                   String           @id @default(cuid())
  code                 String           @unique
  name                 String
  category             ServiceCategory
  unit                 String
  priceMode            ServicePriceMode
  priceSetup           ServicePriceSetup
  status               ServiceStatus    @default(ACTIVE)
  description          String?
  supplierName         String?
  contactInfo          String?
  province             String?
  formulaCount         FormulaOption?
  formulaCountDefault  String?
  formulaQuantity      FormulaOption?
  formulaQuantityDefault String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  prices               ServicePrice[]
}

model ServicePrice {
  id             String    @id @default(cuid())
  serviceId      String
  unitPrice      Decimal   @db.Decimal(12, 2)
  note           String?
  effectiveDate  DateTime
  endDate        DateTime
  createdByName  String
  createdAt      DateTime  @default(now())

  service        Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model TourGuide {
  id               String   @id @default(cuid())
  code             String   @unique
  fullName         String
  gender           Gender
  dateOfBirth      DateTime
  phone            String
  email            String?
  address          String?
  operatingArea    String?
  guideCardNumber  String
  issueDate        DateTime?
  expiryDate       DateTime?
  issuePlace       String?
  note             String?
  languagesJson    Json
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BlogPost {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  category         String
  excerpt          String?
  contentMarkdown  String
  coverImageUrl    String?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model WishlistItem {
  id            String      @id @default(cuid())
  userId        String
  tourProgramId String
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tourProgram   TourProgram @relation(fields: [tourProgramId], references: [id], onDelete: Cascade)

  @@unique([userId, tourProgramId])
  @@index([userId, createdAt])
}

model TourReview {
  id             String       @id @default(cuid())
  bookingId      String       @unique
  userId         String?
  tourProgramId  String
  tourInstanceId String
  rating         Int
  title          String?
  comment        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  tourProgram    TourProgram  @relation(fields: [tourProgramId], references: [id], onDelete: Cascade)
  tourInstance   TourInstance @relation(fields: [tourInstanceId], references: [id], onDelete: Cascade)

  @@index([tourProgramId, createdAt])
  @@index([tourInstanceId, createdAt])
}
